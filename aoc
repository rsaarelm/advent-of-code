#[derive(Parser, Debug)]
#[command(author, version, about)]
struct Args {
    #[command(subcommand)]
    command: Option<Cmd>,
}

#[derive(Subcommand, Debug)]
enum Cmd {
    /// Run a task.
    Run {
        /// The language and day of the task, eg. "rs/1501" for Rust task for 2015-12-01.
        /// Assumes Rust and the latest valid day if unspecified.
        task: Option<String>,
    },

    /// Save the output of a correctly working task as the official answer.
    Canonize {
        /// The language and day of the task, eg. "rs/1501" for Rust task for 2015-12-01.
        task: String,
    },
}

trait DateExt {
    /// Format used by aoc tool, 2015-12-01 becomes 1501
    fn code(&self) -> String;
}

impl<T: Datelike + Sized> DateExt for T {
    fn code(&self) -> String {
        format!("{:02}{:02}", self.year() - 2000, self.day())
    }
}

fn start_times() -> impl Iterator<Item = DateTime<Utc>> {
    (2015..).flat_map(|year| {
        (1..=25).map(move |day| Utc.with_ymd_and_hms(year, 12, day, 5, 0, 0).unwrap())
    })
}

fn download_input(cookie: &str, date: DateTime<Utc>) -> anyhow::Result<String> {
    let client = reqwest::blocking::Client::new();
    let url = format!(
        "https://adventofcode.com/{}/day/{}/input",
        date.year(),
        date.day()
    );
    let response = client
        .get(url)
        .header("Cookie", format!("session={}", cookie))
        .send()?;

    if response.status().is_success() {
        Ok(response.text()?)
    } else {
        bail!("Failed {:?}", response.status());
    }
}

fn get_cookie() -> anyhow::Result<String> {
    match std::env::var("ADVENT_SESSION") {
        Ok(cookie) => Ok(cookie),
        Err(_) => bail!("Set the environment variable 'ADVENT_SESSION' to the value of your 'session' cookie from adventofcode.com"),
    }
}

fn ensure_input_dir() -> anyhow::Result<()> {
    let input_dir = Path::new("input");
    if !input_dir.exists() {
        eprintln!("Creating input/ directory");
        fs::create_dir(input_dir)?;
    }
    Ok(())
}

fn input(task: &str) -> anyhow::Result<String> {
    let path = format!("input/{task}.txt");
    let path = Path::new(&path);

    // Input already exists, good to go.
    if path.exists() {
        return Ok(fs::read_to_string(path)?);
    }

    ensure_input_dir()?;

    // TODO Unify the task format, parseable type?, can use it with cookie DL
    // TODO When running a task, download input/1501.txt first if it's missing (no need for explicit download cmd)
    todo!("Download missing input")
}

fn run(lang: &str, task: &str) -> anyhow::Result<String> {
    let mut command = process::Command::new("just")
        .arg("run")
        .arg(task)
        .current_dir(lang)
        .stdin(Stdio::piped())
        .stdout(Stdio::piped())
        .stderr(Stdio::inherit())
        .spawn()?;

    let mut stdin = command.stdin.take().unwrap();
    let input = input(task)?;
    std::thread::spawn(move || {
        stdin.write_all(input.as_bytes()).unwrap();
    });

    let output = command.wait_with_output()?;

    Ok(String::from_utf8_lossy(&output.stdout).to_string())
}

fn main() -> anyhow::Result<()> {
    let args = Args::parse();
    let now = chrono::Utc::now();

    let next = start_times().find(|&x| x > now).unwrap();
    println!("{} until next task", (next - now).human(Truncate::Second));

    match &args {
        Args {
            command: Some(Cmd::Run { task: Some(task) }),
        } => {
            let [lang, task] = task.split('/').collect::<Vec<_>>()[..] else {
                bail!("Bad task")
            };
            let ret = run(lang, task)?;
            print!("{ret}");
        }
        _ => {}
    }

    //let test_day = start_times().next().unwrap();
    //println!("{:?}", download_input(&get_cookie()?, test_day));

    Ok(())
}

